{
  "manifest_version": 3,
  "name": "Koalagram",
  "version": "0.1.0",
  "description": "A Scaledrone-backed chat extension with saved channels, presence, and local history.",
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "minimum_chrome_version": "114",
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "icons": {
    "16": "src/assets/icon.png",
    "32": "src/assets/icon.png",
    "48": "src/assets/icon.png",
    "128": "src/assets/icon.png"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_icon": {
      "16": "src/assets/icon.png",
      "32": "src/assets/icon.png",
      "48": "src/assets/icon.png",
      "128": "src/assets/icon.png"
    },
    "default_title": "Open Koalagram"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' wss://api.scaledrone.com"
  }
}
